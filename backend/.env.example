# Server
PORT=5000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_URI_DIRECT=
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGO_CONNECT_RETRIES=3
MONGO_CONNECT_RETRY_DELAY_MS=2000

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# Frontend/backend URLs (production)
FRONTEND_ORIGINS=https://booksmart.dev,https://www.booksmart.dev
FRONTEND_URL=https://booksmart.dev
BACKEND_BASE_URL=https://api.booksmart.dev

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (booking notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# Gmail OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://api.booksmart.dev/api/auth/gmail/callback
